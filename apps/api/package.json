{
  "name": "@terraqura/api",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@terraqura/types": "workspace:*",
    "drizzle-orm": "^0.29.3",
    "ethers": "^6.10.0",
    "fastify": "^5.8.4",
    "pg": "^8.11.3",
    "pino": "^8.18.0",
    "siwe": "^2.1.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@terraqura/eslint-config": "workspace:*",
    "@terraqura/typescript-config": "workspace:*",
    "@types/node": "^20.11.5",
    "@types/pg": "^8.10.9",
    "@vitest/coverage-v8": "^1.6.1",
    "drizzle-kit": "^0.30.4",
    "eslint": "^8.57.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  }
}
