{
  "name": "@terraqura/sdk",
  "version": "0.1.0",
  "description": "Enterprise-grade TypeScript SDK for TerraQura carbon credit platform",
  "private": true,
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.mts",
    "test:watch": "vitest --config vitest.config.mts",
    "test:coverage": "vitest run --config vitest.config.mts --coverage"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.7.0",
    "@terraqura/types": "workspace:*",
    "ethers": "^6.10.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@terraqura/eslint-config": "workspace:*",
    "@terraqura/typescript-config": "workspace:*",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.57.0",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4"
  }
}
